---
interface Reference {
  id: number;
  authors: string;
  title: string;
  journal: string;
  year: number;
  pmid?: string;
}

interface Props {
  id: number;
}

const { id } = Astro.props;

const data = (Astro.locals.starlightRoute?.entry?.data as any);
const references: Reference[] = data?.references ?? [];
const ref = references.find((r: Reference) => r.id === id);
---

{ref ? (
  <span class="cite">
    <a href={`#ref-${id}`} class="cite__link">[{id}]</a>
    <span class="cite__tooltip" role="tooltip">
      <span class="cite__authors">{ref.authors}.</span>
      <span class="cite__title">{ref.title}.</span>
      <span class="cite__source"><em>{ref.journal}</em>. {ref.year}.</span>
      {ref.pmid && (
        <a
          href={`https://pubmed.ncbi.nlm.nih.gov/${ref.pmid}/`}
          target="_blank"
          rel="noopener noreferrer"
          class="cite__pubmed"
        >
          PubMed →
        </a>
      )}
    </span>
  </span>
) : (
  <span class="cite cite--missing" title={`参考文献 ${id} が見つかりません`}>[{id}]</span>
)}

<style>
  .cite {
    position: relative;
    display: inline;
  }

  .cite__link {
    color: var(--rw-accent, #1a73e8);
    text-decoration: none;
    font-size: 0.72em;
    vertical-align: super;
    font-weight: 700;
    line-height: 1;
    padding: 0 1px;
    transition: color 0.15s;
  }

  .cite__link:hover {
    color: var(--rw-accent-high, #1557b0);
    text-decoration: underline;
  }

  .cite__tooltip {
    visibility: hidden;
    opacity: 0;
    pointer-events: none;
    position: absolute;
    bottom: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%);
    min-width: 260px;
    max-width: 340px;
    background: #1a2744;
    color: #cfe0f5;
    border: 1px solid #3a5a8a;
    border-radius: 6px;
    padding: 0.7rem 0.9rem;
    font-size: 0.76rem;
    line-height: 1.55;
    z-index: 500;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.35);
    transition: opacity 0.15s, visibility 0.15s;
    white-space: normal;
    text-align: left;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    font-style: normal;
    font-weight: normal;
    vertical-align: baseline;
  }

  /* Downward arrow */
  .cite__tooltip::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 6px solid transparent;
    border-top-color: #1a2744;
  }

  /* Invisible bridge to prevent hover gap */
  .cite__tooltip::before {
    content: '';
    position: absolute;
    top: calc(100% - 1px);
    left: -12px;
    right: -12px;
    height: 16px;
  }

  .cite:hover .cite__tooltip {
    visibility: visible;
    opacity: 1;
    pointer-events: auto;
  }

  .cite__authors {
    color: #a8c0e0;
    font-size: 0.73rem;
  }

  .cite__title {
    color: #f0f4ff;
    font-style: italic;
    font-size: 0.75rem;
  }

  .cite__source {
    color: #a8c0e0;
    font-size: 0.73rem;
  }

  .cite__pubmed {
    color: #7ab3e8;
    text-decoration: none;
    font-size: 0.72rem;
    margin-top: 0.15rem;
    display: inline-block;
  }

  .cite__pubmed:hover {
    text-decoration: underline;
    color: #ffffff;
  }

  .cite--missing {
    color: #e07070;
    font-size: 0.72em;
    vertical-align: super;
    font-weight: 700;
  }
</style>
