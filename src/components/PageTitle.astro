---
// PAGE_TITLE_ID は Starlight 内部定数。値は '_top' で固定。
const PAGE_TITLE_ID = '_top';

// URLセグメント → 日本語ラベルのマッピング
const segmentLabels: Record<string, string> = {
  diseases:            '疾患別',
  gynecology:          '婦人科',
  ovary:               '卵巣腫瘍',
  bone:                '骨腫瘍',
  general:             '総論',
  'who-classification': 'WHO分類（第5版）',
  osteogenic:          '骨形成性腫瘍',
  chondrogenic:        '軟骨形成性腫瘍',
  gct:                 '骨巨細胞腫',
  'small-round-cell':  '小円形細胞・その他',
  brain:               '中枢神経',
  spine:               '脊椎・脊髄',
  'head-neck':         '頭頸部',
  musculoskeletal:     '骨・関節・軟部',

  chest:               '呼吸器・縦隔',
  cardiovascular:      '心・血管・脈管',
  breast:              '乳腺',
  hepatobiliary:       '消化器（肝・胆・膵・脾）',
  gi:                  '消化器（消化管）',
  urinary:             '泌尿器',
  pediatrics:          '小児',
  ivr:                 'IVR',
  nuclear:             '核医学',
  differentials:       '鑑別診断',
};

// パンくずに表示しないセグメント（href 構築には使う）
const skipSegments = new Set(['diseases']);

// ベースURL（末尾スラッシュを除去して正規化）
const base = import.meta.env.BASE_URL.replace(/\/?$/, ''); // '/radiology-wiki'
const pathname = Astro.url.pathname;

// スラグを安全に抽出：先頭スラッシュを確実に除去してから処理
const slug = pathname
  .slice(base.length)          // base より後を切り出し → '/diseases/bone/general/imaging/'
  .replace(/^\/+|\/+$/g, ''); // 先頭・末尾スラッシュを除去 → 'diseases/bone/general/imaging'

const pageTitle = Astro.locals.starlightRoute.entry.data.title;
const allSegments = slug ? slug.split('/') : [];
const parentSegments = allSegments.slice(0, -1);

type BreadcrumbItem = { label: string; href?: string };

// 表示セグメントのアイテムを生成（skipSegments は表示をスキップするが href 構築には含める）
const intermediateItems: BreadcrumbItem[] = parentSegments
  .filter((seg) => !skipSegments.has(seg))
  .map((seg) => {
    const segIndex = allSegments.indexOf(seg);
    const href = base + '/' + allSegments.slice(0, segIndex + 1).join('/') + '/';
    return { label: segmentLabels[seg] ?? seg, href };
  });

const breadcrumbs: BreadcrumbItem[] = [
  { label: '画像診断Wiki', href: base + '/' },
  ...intermediateItems,
  { label: pageTitle },
];
---

{breadcrumbs.length > 1 && (
  <nav aria-label="パンくずリスト" class="breadcrumb-nav" data-pagefind-ignore>
    <ol>
      {breadcrumbs.map((item) => (
        <li>
          {item.href ? (
            <a href={item.href}>{item.label}</a>
          ) : (
            <span aria-current="page">{item.label}</span>
          )}
        </li>
      ))}
    </ol>
  </nav>
)}

<h1 id={PAGE_TITLE_ID} data-pagefind-meta="title">{pageTitle}</h1>

<style>
  .breadcrumb-nav {
    margin-bottom: 0.75rem;
    font-size: 0.8em;
  }

  .breadcrumb-nav ol {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0;
  }

  /* セパレーターは ::after で単一生成 */
  .breadcrumb-nav li:not(:last-child)::after {
    content: '›';
    margin: 0 0.35rem;
    color: var(--sl-color-gray-4);
    font-size: 0.9em;
  }

  .breadcrumb-nav a {
    color: #1a73e8;
    text-decoration: none;
  }

  .breadcrumb-nav a:hover {
    text-decoration: underline;
  }

  .breadcrumb-nav [aria-current="page"] {
    color: var(--sl-color-text);
  }

  h1 {
    margin-top: 0.5rem;
    font-size: var(--sl-text-h1);
    line-height: var(--sl-line-height-headings);
    font-weight: 600;
    color: var(--sl-color-white);
  }
</style>
