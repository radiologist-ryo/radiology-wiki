---
// PAGE_TITLE_ID は Starlight 内部定数。値は '_top' で固定。
const PAGE_TITLE_ID = '_top';

// URLセグメントからパンくずラベルへのマッピング
// 'diseases' は疾患ルートとして非表示にし、配下のセグメントのみ表示する
const segmentLabels: Record<string, string> = {
  gynecology:      '婦人科',
  ovary:           '卵巣腫瘍',
  brain:           '中枢神経',
  spine:           '脊椎・脊髄',
  'head-neck':     '頭頸部',
  musculoskeletal: '骨・関節・軟部',
  chest:           '呼吸器・縦隔',
  cardiovascular:  '心・血管・脈管',
  breast:          '乳腺',
  hepatobiliary:   '消化器（肝・胆・膵・脾）',
  gi:              '消化器（消化管）',
  urinary:         '泌尿器',
  pediatrics:      '小児',
  ivr:             'IVR',
  nuclear:         '核医学',
  differentials:   '鑑別診断',
};

// このセグメントはパンくずから除外（疾患ルートパス）
const skipSegments = new Set(['diseases']);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const pathname = Astro.url.pathname;
const slug = pathname.replace(import.meta.env.BASE_URL, '').replace(/\/$/, '');
const pageTitle = Astro.locals.starlightRoute.entry.data.title;

// スラッグをセグメントに分割し、最後のセグメントを除いた親セグメントを取得
const segments = slug.split('/');
const parentSegments = segments.slice(0, -1).filter((s) => !skipSegments.has(s));

type BreadcrumbItem = { label: string; href?: string };

const breadcrumbs: BreadcrumbItem[] = [
  { label: '画像診断Wiki', href: base + '/' },
  ...parentSegments.map((s) => ({ label: segmentLabels[s] ?? s })),
  { label: pageTitle },
];
---

{breadcrumbs.length > 1 && (
  <nav aria-label="パンくずリスト" class="breadcrumb-nav">
    <ol>
      {breadcrumbs.map((item, index) => (
        <li>
          {item.href ? (
            <a href={item.href}>{item.label}</a>
          ) : index < breadcrumbs.length - 1 ? (
            <span>{item.label}</span>
          ) : (
            <span aria-current="page">{item.label}</span>
          )}
          {index < breadcrumbs.length - 1 && (
            <span aria-hidden="true" class="separator">›</span>
          )}
        </li>
      ))}
    </ol>
  </nav>
)}

<h1 id={PAGE_TITLE_ID}>{pageTitle}</h1>

<style>
  .breadcrumb-nav {
    margin-bottom: 0.75rem;
    font-size: 0.8em;
  }

  .breadcrumb-nav ol {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.2rem;
  }

  .breadcrumb-nav li {
    display: flex;
    align-items: center;
    gap: 0.2rem;
  }

  .breadcrumb-nav a {
    color: var(--sl-color-accent);
    text-decoration: none;
  }

  .breadcrumb-nav a:hover {
    text-decoration: underline;
  }

  .breadcrumb-nav .separator {
    color: var(--sl-color-gray-4);
    font-size: 0.9em;
  }

  .breadcrumb-nav span {
    color: var(--sl-color-gray-3);
  }

  .breadcrumb-nav [aria-current="page"] {
    color: var(--sl-color-text);
  }

  h1 {
    margin-top: 0.5rem;
    font-size: var(--sl-text-h1);
    line-height: var(--sl-line-height-headings);
    font-weight: 600;
    color: var(--sl-color-white);
  }
</style>
