---
// PAGE_TITLE_ID は Starlight 内部定数。値は '_top' で固定。
const PAGE_TITLE_ID = '_top';

// URLセグメントからパンくずラベルへのマッピング
// 'diseases' は疾患ルートとして表示から除外するが、href構築には使用する
const segmentLabels: Record<string, string> = {
  gynecology:      '婦人科',
  ovary:           '卵巣腫瘍',
  brain:           '中枢神経',
  spine:           '脊椎・脊髄',
  'head-neck':     '頭頸部',
  musculoskeletal: '骨・関節・軟部',
  chest:           '呼吸器・縦隔',
  cardiovascular:  '心・血管・脈管',
  breast:          '乳腺',
  hepatobiliary:   '消化器（肝・胆・膵・脾）',
  gi:              '消化器（消化管）',
  urinary:         '泌尿器',
  pediatrics:      '小児',
  ivr:             'IVR',
  nuclear:         '核医学',
  differentials:   '鑑別診断',
};

// ラベルには出さないが href には含めるセグメント
const skipSegments = new Set(['diseases']);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const pathname = Astro.url.pathname;
const slug = pathname.replace(import.meta.env.BASE_URL, '').replace(/\/$/, '');
const pageTitle = Astro.locals.starlightRoute.entry.data.title;

// 全セグメントを保持しつつ、ラベル・href・skipを計算
const allSegments = slug.split('/');
const parentSegments = allSegments.slice(0, -1);

type BreadcrumbItem = { label: string; href?: string };

// 親セグメントをパンくずアイテムに変換（skipは非表示だが href 構築には含める）
const intermediateItems: BreadcrumbItem[] = parentSegments
  .filter((seg) => !skipSegments.has(seg))
  .map((seg) => {
    const segIndex = allSegments.indexOf(seg);
    const href = base + '/' + allSegments.slice(0, segIndex + 1).join('/') + '/';
    return { label: segmentLabels[seg] ?? seg, href };
  });

const breadcrumbs: BreadcrumbItem[] = [
  { label: '画像診断Wiki', href: base + '/' },
  ...intermediateItems,
  { label: pageTitle },
];
---

{breadcrumbs.length > 1 && (
  <nav aria-label="パンくずリスト" class="breadcrumb-nav">
    <ol>
      {breadcrumbs.map((item) => (
        <li>
          {item.href ? (
            <a href={item.href}>{item.label}</a>
          ) : (
            <span aria-current="page">{item.label}</span>
          )}
        </li>
      ))}
    </ol>
  </nav>
)}

<h1 id={PAGE_TITLE_ID}>{pageTitle}</h1>

<style>
  .breadcrumb-nav {
    margin-bottom: 0.75rem;
    font-size: 0.8em;
  }

  .breadcrumb-nav ol {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
  }

  /* セパレーターはCSSの::afterで生成（JSXでの二重レンダリングを防ぐ） */
  .breadcrumb-nav li:not(:last-child)::after {
    content: '›';
    margin: 0 0.35rem;
    color: var(--sl-color-gray-4);
    font-size: 0.9em;
  }

  .breadcrumb-nav a {
    color: #1a73e8;
    text-decoration: none;
  }

  .breadcrumb-nav a:hover {
    text-decoration: underline;
  }

  .breadcrumb-nav [aria-current="page"] {
    color: var(--sl-color-text);
  }

  h1 {
    margin-top: 0.5rem;
    font-size: var(--sl-text-h1);
    line-height: var(--sl-line-height-headings);
    font-weight: 600;
    color: var(--sl-color-white);
  }
</style>
