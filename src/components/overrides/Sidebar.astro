---
/**
 * Custom Sidebar override.
 * Shows only the section tree relevant to the current URL path:
 *   /obgyn/*                 → 産婦人科 tree
 *   /diseases/bone/*         → 骨・関節・軟部 tree
 *   /diseases/soft-tissue/*  → 骨・関節・軟部 tree
 *   /diseases/musculoskeletal/* → 骨・関節・軟部 tree
 *   otherwise                → full sidebar
 *
 * isCurrent flags are computed by Starlight via Astro.locals.starlightRoute.sidebar,
 * so we just filter the pre-processed data.
 */
import type { Props } from '@astrojs/starlight/props';
import MobileMenuFooter from 'virtual:starlight/components/MobileMenuFooter';
import SidebarList from './SidebarList.astro';

type SidebarLink = {
	type: 'link';
	label: string;
	href: string;
	isCurrent: boolean;
	badge?: unknown;
	attrs?: Record<string, unknown>;
};
type SidebarGroup = {
	type: 'group';
	label: string;
	entries: SidebarEntry[];
	collapsed: boolean;
	badge?: unknown;
};
type SidebarEntry = SidebarLink | SidebarGroup;

// Full sidebar (with isCurrent flags set by Starlight)
const sidebar = (Astro.locals.starlightRoute as any).sidebar as SidebarEntry[];
const pathname = Astro.url.pathname;
const base = '/radiology-wiki';

function filterTopLevel(label: string): SidebarEntry[] | null {
	const match = sidebar.find(
		(e): e is SidebarGroup => e.type === 'group' && e.label === label
	);
	if (!match) return null;
	return [{ ...match, collapsed: false }];
}

let filtered: SidebarEntry[] | null = null;

if (pathname.includes('/obgyn/')) {
	filtered = filterTopLevel('産婦人科');
} else if (
	pathname.includes('/diseases/bone') ||
	pathname.includes('/diseases/soft-tissue') ||
	pathname.includes('/diseases/musculoskeletal')
) {
	filtered = filterTopLevel('骨・関節・軟部');
}

const displayEntries: SidebarEntry[] = filtered ?? sidebar;
---

<SidebarList entries={displayEntries} />

<div class="md:sl-hidden">
	<MobileMenuFooter />
</div>

<script is:inline>
(function () {
	function initSidebarHandlers() {
		document.querySelectorAll('nav.sidebar details > summary').forEach(function (summary) {
			summary.addEventListener('click', function (e) {
				var link = e.target.closest('a.group-label-link');
				if (link) {
					// <a> クリック: details の toggle を防いでナビゲーション
					e.preventDefault();
					window.location.assign(link.href);
					return;
				}
				var caretBtn = e.target.closest('.caret-btn');
				if (caretBtn) {
					// caret クリック: details.open を手動 toggle し、summary の default は防ぐ
					e.preventDefault();
					var details = summary.closest('details');
					details.open = !details.open;
					caretBtn.setAttribute('aria-expanded', String(details.open));
					return;
				}
				// summary 余白クリック: default の toggle を防ぐ（caret 専用にする）
				e.preventDefault();
			});
		});
	}

	document.addEventListener('DOMContentLoaded', initSidebarHandlers);
	// Astro View Transitions 対応
	document.addEventListener('astro:page-load', initSidebarHandlers);
})();
</script>

